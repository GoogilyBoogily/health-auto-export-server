NODE_ENV=development
API_TOKEN=sk-your-api-token-here
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Sleep session gap threshold in minutes (default: 30)
# If gap between sleep segments exceeds this, a new session starts
SLEEP_SESSION_GAP_MINUTES=30

# Obsidian daily tracking path (relative to OBSIDIAN_VAULT_PATH)
# Default path uses Johnny Decimal numbering
# OBSIDIAN_DAILY_PATH=70-79 Journals & Self-Tracking/72 Daily Tracking

# Obsidian daily file body template (use \n for newlines)
# OBSIDIAN_DAILY_TEMPLATE=## Habit Log\n\n## Mood Log\n\n## Bullet Journal\n\n## Workout Log\n\n## Sleep Log\n\n# {{date}}\n\n## Health Metrics
